// ⚠️ DEVELOPMENT ONLY — These rules allow public read/write access.
// NEVER deploy to production. Before launch, replace with authenticated rules.
// Production example:
//   allow read, write: if request.auth != null;
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
