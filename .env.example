# OpenAI
OPENAI_API_KEY=sk-proj-...

# Firebase (solo necesitas PROJECT_ID, API_KEY y STORAGE_BUCKET)
FIREBASE_API_KEY=AIzaSy...
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app

# Servidor
PORT=3001
BACKEND_URL=https://tu-app.onrender.com   # URL pública del servidor (para logs)

# WhatsApp (Baileys)
WHATSAPP_ENABLED=true      # true en producción
RESTAURANTE_ID=urbano      # ID del restaurante en Firestore

# Elasticsearch (opcional — para métricas en Kibana)
ELASTICSEARCH_URL=http://elasticsearch:9200
